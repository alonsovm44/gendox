# ==============================================================================
# Gendox Environment Configuration
# ==============================================================================
# Copy this file to '.env' and modify it to suit your environment.
# Do NOT commit your actual .env file to version control.

# ------------------------------------------------------------------------------
# Backend Selection
# ------------------------------------------------------------------------------
# Mode: 'local' (Ollama) or 'cloud' (OpenAI, Gemini, etc.)
GENDOX_MODE=local

# ------------------------------------------------------------------------------
# Local Backend Settings (Ollama)
# ------------------------------------------------------------------------------
# Use http://ollama:11434 if running Gendox via Docker Compose
OLLAMA_HOST=http://localhost:11434
OLLAMA_MODEL=qwen2.5-coder:7b

# ------------------------------------------------------------------------------
# Cloud Backend Settings (OpenAI / Gemini / Anthropic)
# ------------------------------------------------------------------------------
# Protocol: 'openai' (compatible with OpenAI, Groq, DeepSeek, etc.)
GENDOX_PROTOCOL=openai
GENDOX_KEY=your-api-key-here
GENDOX_MODEL=gpt-4o

# ------------------------------------------------------------------------------
# Project & Style Settings
# ------------------------------------------------------------------------------
# Path to the project to document (relative to CWD)
GENDOX_PROJECT_PATH=.

# Documentation Style (comma-separated instructions)
GENDOX_STYLE=professional,concise,no-emojis

# ------------------------------------------------------------------------------
# Development / Debugging
# ------------------------------------------------------------------------------
# Log Level: debug, info, warn, error
GENDOX_LOG_LEVEL=info